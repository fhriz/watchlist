<% content_for :title, "Movies" %>

<div class="w-full">
  <% if notice.present? %>
    <div class="alert alert-success mb-6" id="notice">
      <span class="alert-icon">✓</span>
      <span><%= notice %></span>
    </div>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="ds-h1">Movies</h1>
    <%= link_to "New movie", new_movie_path, class: "btn btn-primary" %>
  </div>

  <div id="filters" class="w-full mb-6">
    <%= form_with url: movies_path, class: "mb-4 flex gap-2", 
      method: :get, 
      data: { 
        turbo_frame: "movies",
        controller: "filter",
        filter_delay_value: 300
      } do |form| %>

      <%= form.text_field :query,
      placeholder: "Search movies...",
      value: params[:query],
      data: {
        filter_target: "query",
        action: "input->filter#submit"
      } %>

      <%= form.select :status,
          options_for_select(Movie.statuses.keys, params[:status]),
          { include_blank: "All Statuses" },
          {
            data: {
              filter_target: "status",
              action: "change->filter#submitNow"
            }
          } %>

      <%#= form.submit "Filter", class: "btn btn-primary w-full mt-2" %>
    <% end %>
  </div>
  <div id="movies">
    <% if @movies.any? %>
      <%= turbo_frame_tag "movies" do %>
      <div class="grid gap-3" style="grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));">
      
        <%= render @movies %>

      </div>
      <% end %> 
    <% else %>
      <div class="card card-flat text-center p-8">
        <p class="ds-text-muted">No movies in your watchlist yet.</p>
        <%= link_to "Add your first movie", new_movie_path, class: "btn btn-primary mt-4" %>
      </div>
    <% end %>
  </div>
</div>
