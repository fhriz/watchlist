<% content_for :title, "Showing movie" %>

<div class="max-w-lg w-full">
  <% if notice.present? %>
    <div class="alert alert-success mb-6" id="notice">
      <span class="alert-icon">✓</span>
      <span><%= notice %></span>
    </div>
  <% end %>

  <div class="card mb-6">
    <div class="card-header">
      <div>
        <div class="card-title"><h1><%= @movie.title %></h1></div>
        <div class="card-subtitle">
          <%= @movie.release_year %> <% if @movie.genre.present? %>| <%= @movie.genre %><% end %>
        </div>
      </div>
    </div>
    <% if @movie.synopsis.present? %>
      <div class="card-body"><%= @movie.synopsis %></div>
    <% end %>
  </div>

  <div class="flex gap-2">
    <%= link_to "Edit", edit_movie_path(@movie), class: "btn btn-primary" %>
    <%= link_to "Back to movies", movies_path, class: "btn btn-ghost" %>
    <%= button_to "Delete", @movie, method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
